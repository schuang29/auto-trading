# Alpaca Paper Trading — get keys at https://app.alpaca.markets/paper-trading/overview
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# GitHub push credential for the headless scheduled context.
# The scheduled (non-interactive) routines cannot use the Windows Credential
# Manager, so the audit-trail push needs a token here. Create a fine-grained
# Personal Access Token scoped to ONLY the auto-trading repo with
# Contents: Read and write, paste it below as GITHUB_TOKEN.
# This file (.env.example) is a TEMPLATE — never put the real token here;
# it goes in .env, which is gitignored. scripts/sync_git.ps1 reads it.
GITHUB_TOKEN=

# Alerting — used NOW by scripts/heartbeat.py (dead-man's-switch) and the
# routine push-verify step. Fill these in to receive email when the bot goes
# dark or an audit-trail push fails. Until set, alerts still land locally in
# memory/health/ and as a non-zero exit; email is the extra reach.
# Gmail: use an App Password (not your account password), SMTP_PORT 587.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=

# Optional: Slack webhook (Phase 5 — not yet wired)
SLACK_WEBHOOK_URL=
